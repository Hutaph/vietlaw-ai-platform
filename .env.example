# VietLaw AI environment template
# Copy this file to .env, then adjust values for native or Docker execution.
# Do not commit the resulting .env file or real API keys.
# Inference provider keys are managed on the backend host. Do not expose them
# through NEXT_PUBLIC_* variables.

# ==================================================
# 1. Frontend and backend URLs
# ==================================================

APP_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
# Optional compatibility fallback used by a few frontend proxy routes.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Runtime profile: local uses fine-tuned filesystem models; serverless uses
# Hugging Face API embedding and deployment-safe remote reranking.
RUNTIME_PROFILE=local

# Chat history storage is independent from the shared legal corpus storage.
# postgres is shared and unauthenticated; browser keeps sessions on this device.
CHAT_STORAGE_MODE=postgres
NEXT_PUBLIC_CHAT_STORAGE_MODE=postgres


# ==================================================
# 2. External provider keys
# ==================================================
# Leave Hugging Face empty when local embedding/reranking mode is enabled.
# Configure answer-generation provider keys here on the backend only.

HUGGINGFACE_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

ENABLE_GOOGLE_FALLBACK=false
GOOGLE_FALLBACK_MODEL=gemini-3.1-flash-lite
GOOGLE_OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# OPENAI_API_KEY may also be used by optional Ragas evaluation scripts.


# ==================================================
# 3. Embeddings
# ==================================================
# The accepted quality runtime uses the fine-tuned local embedding artifact so
# query vectors stay in the same embedding space as the indexed corpus.
# API mode is supported only when corpus and queries use the same model/space;
# it is not the accepted quality baseline for the current Qdrant collection.
EMBEDDING_PROVIDER=huggingface
HUGGINGFACE_EMBEDDING_MODE=local
HUGGINGFACE_EMBEDDING_MODEL=../models/embedding/vietlaw-bge-m3-finetuned/best
# When set to cuda, Docker Compose must grant GPU access to both backend
# and ingest because backend startup preloads/warmups local embeddings.
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DIMENSION=1024
EMBEDDING_NORMALIZE=true

# Prevent Transformers/SentenceTransformer from downloading files.
LOCAL_MODELS_OFFLINE=true

# Startup preload moves local model loading out of the first user request.
# Warm-up runs one synthetic embedding/reranker inference and does not call
# Qdrant, PostgreSQL, Gemini, or semantic cache. Set either flag to false to
# restore lazy request-time loading. Backend readiness may take around 90s;
# configure deployment startup/readiness timeouts above 120s.
LOCAL_MODELS_PRELOAD_ENABLED=true
LOCAL_MODELS_WARMUP_ENABLED=true

# These retry values mainly apply to batch operations.
EMBEDDING_MAX_RETRIES=3
EMBEDDING_SLEEP_BETWEEN_BATCHES=5
EMBEDDING_RETRY_BASE_WAIT=15


# ==================================================
# 4. Local Ollama
# ==================================================
# Used for local answer generation when INFERENCE_STRATEGY=local_first.
# OLLAMA_EMBEDDING_MODEL is not used by the main retrieval pipeline because
# query embedding is handled by the fine-tuned model configured above.

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=bge-m3
OLLAMA_EMBEDDING_TIMEOUT=300


# ==================================================
# 5. Storage
# Supported values: faiss, qdrant, qdrant_postgres, postgres, postgresql.
# Default to faiss while corpus storage is being restructured so the app does
# not connect to PostgreSQL/Qdrant unless explicitly configured.
STORAGE_BACKEND=faiss
CORPUS_JSONL_PATH=corpus/processed/legal-corpus.jsonl
CORPUS_EMBED_LEVELS=article,clause,point
# Set these only when enabling qdrant_postgres again.
# POSTGRES_DSN=postgresql://postgres:postgres@localhost:15432/vietlaw
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
# QDRANT_COLLECTION=vietlaw_clauses_v3
# QDRANT_TIMEOUT=180
# QDRANT_MAX_RETRIES=6
# QDRANT_UPSERT_BATCH_SIZE=64
# Do not auto-ingest during backend startup.
DISABLE_AUTO_INGEST=true

# Disabled by default to avoid silently querying a stale FAISS index when
# Qdrant Cloud auth/schema/collection checks fail. Enable only if the FAISS
# index was built with the same active embedding model.
ENABLE_FAISS_FALLBACK=false


# ==================================================
# 6. RAG pipeline
# ==================================================

PIPELINE_CHUNKING=clause
# This value is used only for the FAISS path. When STORAGE_BACKEND is
# qdrant_postgres/qdrant, the runtime creates QdrantSearcher and performs
# dense+sparse hybrid retrieval with manual RRF.
PIPELINE_SEARCH=faiss

# Enable the fine-tuned local cross-encoder reranker.
PIPELINE_RERANKING=cross_encoder

PIPELINE_CONTEXT_BUILDER=nested
PIPELINE_REWRITER=none

REWRITER_MODEL_PROVIDER=ollama
REWRITER_MODEL_NAME=qwen2.5:1.5b


# ==================================================
# 7. Fine-tuned local reranker
# ==================================================
# The stable selected symlink currently points to the accepted reranker
# candidate. No external reranking API is used by the accepted quality
# configuration.

RERANKER_MODEL=../models/reranking/vietlaw-bge-reranker-v2-m3-finetuned/checkpoint-3306
RERANKER_DEVICE=cpu
RERANKER_BATCH_SIZE=8
RERANKER_MAX_LENGTH=512
RERANKER_FAIL_OPEN=false
RERANKER_MAX_CANDIDATES=10

RETRIEVER_CANDIDATE_K=10

# Reserved for experimental weighted-hybrid implementations; the current
# Qdrant path uses rank-based RRF and does not apply these weights.
HYBRID_VECTOR_WEIGHT=0.5
HYBRID_BM25_WEIGHT=0.5


# ==================================================
# 8. Pipeline timing instrumentation
# ==================================================
# Emit one structured pipeline_timing log per chat request. Disabled by
# default and intended for short local baseline measurements only.

PIPELINE_TIMING_ENABLED=false


# ==================================================
# 9. Semantic cache
# ==================================================
# Keep disabled during initial embedding/reranker verification so every
# request passes through:
#
# local embedding -> Qdrant Cloud -> local reranker
#
# Enable it only after the retrieval flow has been validated.

ENABLE_SEMANTIC_CACHE=false
SEMANTIC_CACHE_THRESHOLD=0.95
SEMANTIC_CACHE_COLLECTION=semantic_cache_bge_m3_ft_v1


# ==================================================
# 10. Inference strategy
# ==================================================
# local_first uses local Ollama first.
# Remote providers are used only if explicitly configured as fallbacks.

INFERENCE_STRATEGY=remote_first

# Serverless deployment override:
# RUNTIME_PROFILE=serverless
# CHAT_STORAGE_MODE=browser
# NEXT_PUBLIC_CHAT_STORAGE_MODE=browser
# HUGGINGFACE_EMBEDDING_MODE=api
# HUGGINGFACE_EMBEDDING_MODEL=BAAI/bge-m3
# PIPELINE_RERANKING=embedding_similarity
# LOCAL_MODELS_PRELOAD_ENABLED=false
# LOCAL_MODELS_WARMUP_ENABLED=false
